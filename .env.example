# OPENSKY_CLIENT_SECRET=your_opensky_client_secret
# MYSHIPTRACKING_API_KEY=your_myshiptracking_api_key
# MYSHIPTRACKING_SECRET_KEY=your_myshiptracking_secret_key
# AGENTMAIL_API_KEY=your_agentmail_api_key
